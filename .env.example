# PR Pilot — Environment Configuration
# Copy to .env and fill in values

# GitHub App
GITHUB_APP_ID=
# Path to the .pem file, or the inline key contents. config.py reads this var.
GITHUB_APP_PRIVATE_KEY=/path/to/private-key.pem
GITHUB_WEBHOOK_SECRET=
# Dev only: allow unsigned webhooks when GITHUB_WEBHOOK_SECRET is empty.
# Never set this in production.
# ALLOW_UNSIGNED_WEBHOOKS=false

# Google Gemini (required by XPRIZE rules)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Optional: secondary LLM for specialized tasks
# SECONDARY_LLM_API_KEY=

# Hosting
HOST=0.0.0.0
PORT=8080

# Logging
LOG_LEVEL=INFO
AGENT_LOG_DIR=./logs/agents
